@model EucSaaS.Web.ViewModels.Dashboard.DashboardTemplateDefinitionViewModel

@{
    ViewData["Title"] = "Create Dashboard Template";
}

<h2>Create Dashboard Template</h2>

<form asp-action="Create" method="post">

    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Template Code</label>
        <input asp-for="TemplateCode" class="form-control" />
        <span asp-validation-for="TemplateCode" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Template Name</label>
        <input asp-for="TemplateName" class="form-control" />
        <span asp-validation-for="TemplateName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea asp-for="Description"
                  class="form-control"
                  rows="3"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Display Order</label>
        <input asp-for="DisplayOrder"
               type="number"
               class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive"
               class="form-check-input" />
        <label asp-for="IsActive"
               class="form-check-label">
            Active
        </label>
    </div>

    <button class="btn btn-primary">
        Save
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
