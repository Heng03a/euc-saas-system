@model EucSaaS.Web.ViewModels.Dynamic.DynamicScreenViewModel

@{
    ViewData["Title"] = Model.ScreenName;

    var searchField1 = Model.SearchValues.ContainsKey("searchField1") ? Model.SearchValues["searchField1"] : "";
    var searchOperator1 = Model.SearchValues.ContainsKey("searchOperator1") ? Model.SearchValues["searchOperator1"] : "contains";
    var searchValue1 = Model.SearchValues.ContainsKey("searchValue1") ? Model.SearchValues["searchValue1"] : "";

    var searchField2 = Model.SearchValues.ContainsKey("searchField2") ? Model.SearchValues["searchField2"] : "";
    var searchOperator2 = Model.SearchValues.ContainsKey("searchOperator2") ? Model.SearchValues["searchOperator2"] : "contains";
    var searchValue2 = Model.SearchValues.ContainsKey("searchValue2") ? Model.SearchValues["searchValue2"] : "";
}

<h1>@Model.ScreenName</h1>

@if (Model.ScreenMode != "Report")
{
<a class="btn btn-primary mb-4"
   href="/Screen/@Model.ScreenCode/Create?returnUrl=@System.Net.WebUtility.UrlEncode(Context.Request.Path + Context.Request.QueryString)">
    + Create New
</a>
}

<form method="get" class="border rounded p-4 mb-4">
    <input type="hidden" name="pageNumber" value="1" />

    <div class="row mb-3 align-items-end">
        <div class="col-md-1 fw-bold">Filter 1</div>

        <div class="col-md-3">
            <label>Field</label>
            <select name="searchField1" class="form-control">
                <option value="">-- Select Field --</option>
                @foreach (var column in Model.Columns.Where(c => c.IsVisible))
                {
                    <option value="@column.FieldName" selected="@(searchField1 == column.FieldName)">
                        @column.DisplayLabel
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label>Operator</label>
            <select name="searchOperator1" class="form-control">
                <option value="contains" selected="@(searchOperator1 == "contains")">Contains</option>
                <option value="equals" selected="@(searchOperator1 == "equals")">Equals</option>
                <option value="starts" selected="@(searchOperator1 == "starts")">Starts With</option>
                <option value="ends" selected="@(searchOperator1 == "ends")">Ends With</option>
            </select>
        </div>



        <div class="col-md-4">
            <label>Value</label>
            <input name="searchValue1" value="@searchValue1" class="form-control" />
        </div>
    </div>

    <div class="row mb-3 align-items-end">
        <div class="col-md-1 fw-bold">Filter 2</div>

        <div class="col-md-3">
            <label>Field</label>
            <select name="searchField2" class="form-control">
                <option value="">-- Select Field --</option>
                @foreach (var column in Model.Columns.Where(c => c.IsVisible))
                {
                    <option value="@column.FieldName" selected="@(searchField2 == column.FieldName)">
                        @column.DisplayLabel
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label>Operator</label>
            <select name="searchOperator2" class="form-control">
                <option value="contains" selected="@(searchOperator2 == "contains")">Contains</option>
                <option value="equals" selected="@(searchOperator2 == "equals")">Equals</option>
                <option value="starts" selected="@(searchOperator2 == "starts")">Starts With</option>
                <option value="ends" selected="@(searchOperator2 == "ends")">Ends With</option>
            </select>
        </div>

        <div class="col-md-4">
            <label>Value</label>
            <input name="searchValue2" value="@searchValue2" class="form-control" />
        </div>
    </div>
<div class="row mb-3 align-items-end">
    <div class="col-md-1 fw-bold">Sorting</div>

    <div class="col-md-3">
        <label>Sort By</label>
        <select name="sortColumn" class="form-control">
            <option value="">-- Default Sort --</option>
            @foreach (var column in Model.Columns.Where(c => c.IsVisible))
            {
                <option value="@column.FieldName" selected="@(Model.SortColumn == column.FieldName)">
                    @column.DisplayLabel
                </option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <label>Direction</label>
        <select name="sortDirection" class="form-control">
            <option value="ASC" selected="@(Model.SortDirection == "ASC")">Ascending</option>
            <option value="DESC" selected="@(Model.SortDirection == "DESC")">Descending</option>
        </select>
    </div>
</div>
<div class="row mb-3 align-items-end">
    <div class="col-md-1 fw-bold">Page Size</div>

    <div class="col-md-2">
        <label>Show</label>
 <select name="pageSize" class="form-control">
    <option value="1" selected="@(Model.PageSize == 1)">1</option>
    <option value="2" selected="@(Model.PageSize == 2)">2</option>
    <option value="10" selected="@(Model.PageSize == 10)">10</option>
    <option value="25" selected="@(Model.PageSize == 25)">25</option>
    <option value="50" selected="@(Model.PageSize == 50)">50</option>
    <option value="100" selected="@(Model.PageSize == 100)">100</option>
</select>

    </div>
</div>

<button type="submit" class="btn btn-primary">Search</button>
<a href="/Screen/@Model.ScreenCode" class="btn btn-secondary">Reset</a>

<button type="submit"
        formaction="/Screen/@Model.ScreenCode/Export"
        class="btn btn-success">
    Export Excel
</button></form>

@if (Model.TotalRecords > 0)
{
    var startRecord = ((Model.PageNumber - 1) * Model.PageSize) + 1;
    var endRecord = Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords);

    <div class="mb-2">
        Showing @startRecord - @endRecord of @Model.TotalRecords records
    </div>
}
<table class="table">
    <thead>
        <tr>
            @foreach (var column in Model.Columns.Where(c => c.IsVisible))
            {
                var nextDirection =
                    Model.SortColumn == column.FieldName && Model.SortDirection == "ASC"
                        ? "DESC"
                        : "ASC";

                var sortIcon = "";

                if (Model.SortColumn == column.FieldName)
                {
                    sortIcon = Model.SortDirection == "ASC" ? "▲" : "▼";
                }

                <th>
                    <a href="?@BuildSortQuery(column.FieldName, nextDirection)"
                       class="text-dark text-decoration-none">
                        @column.DisplayLabel @sortIcon
                    </a>
                </th>
            }

            @if (Model.ScreenMode != "Report")
            {
                <th>Actions</th>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                @foreach (var column in Model.Columns.Where(c => c.IsVisible))
                {
                    <td>
                        @{
                            var value = row.ContainsKey(column.FieldName)
                                ? row[column.FieldName]
                                : null;
                        }

                        @value
                    </td>
                }

                @if (Model.ScreenMode != "Report")
                {
                    <td>
<a class="btn btn-primary btn-sm"
   href="/Screen/@Model.ScreenCode/Edit/@row["Id"]?returnUrl=@System.Net.WebUtility.UrlEncode(Context.Request.Path + Context.Request.QueryString)">
    Edit
</a>

<form method="post"
      action="/Screen/@Model.ScreenCode/Delete/@row["Id"]"
      style="display:inline;"
      onsubmit="return confirm('Are you sure you want to delete this record?');">

    <input type="hidden"
           name="returnUrl"
           value="@(Context.Request.Path + Context.Request.QueryString)" />

    <button type="submit"
            class="btn btn-danger btn-sm">
        Delete
    </button>
</form>

                    </td>
                }
            </tr>
        }
    </tbody>
</table>
@if (Model.TotalPages >= 1)
{
    <nav>
        <ul class="pagination">

            <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                <a class="page-link" href="?@BuildPagingQuery(Model.PageNumber - 1)">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                    <a class="page-link" href="?@BuildPagingQuery(i)">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?@BuildPagingQuery(Model.PageNumber + 1)">
                    Next
                </a>
            </li>

        </ul>
    </nav>

    <form method="get" class="d-flex align-items-center mt-3 gap-2">
        @foreach (var item in Context.Request.Query)
        {
            if (item.Key != "pageNumber")
            {
                <input type="hidden" name="@item.Key" value="@item.Value" />
            }
        }

<input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
        <label class="fw-bold">Go To Page:</label>

        <input type="number"
               name="pageNumber"
               value="@Model.PageNumber"
               min="1"
               max="@Model.TotalPages"
               class="form-control"
               style="width:100px;" />

        <span>of @Model.TotalPages</span>

        <button type="submit" class="btn btn-primary">
            Go
        </button>
    </form>
}

@functions {
    string BuildPagingQuery(int pageNumber)
    {
        var query = Context.Request.Query
            .Where(x => x.Key != "pageNumber")
            .ToDictionary(x => x.Key, x => x.Value.ToString());

        query["pageNumber"] = pageNumber.ToString();

        return string.Join("&",
            query.Select(x =>
                $"{System.Net.WebUtility.UrlEncode(x.Key)}={System.Net.WebUtility.UrlEncode(x.Value)}"));
    }

string BuildSortQuery(string sortColumn, string sortDirection)
{
    var query = Context.Request.Query
        .Where(x => x.Key != "sortColumn"
                 && x.Key != "sortDirection"
                 && x.Key != "pageNumber")
        .ToDictionary(x => x.Key, x => x.Value.ToString());

    query["sortColumn"] = sortColumn;
    query["sortDirection"] = sortDirection;
    query["pageNumber"] = "1";

    return string.Join("&",
        query.Select(x =>
            $"{System.Net.WebUtility.UrlEncode(x.Key)}={System.Net.WebUtility.UrlEncode(x.Value)}"));
}
}


