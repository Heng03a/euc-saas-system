@model EucSaaS.Web.ViewModels.Dynamic.DynamicScreenViewModel

@{
    ViewData["Title"] = Model.ScreenName;

    var searchField1 = Model.SearchValues.ContainsKey("searchField1")
        ? Model.SearchValues["searchField1"]
        : "";

    var searchOperator1 = Model.SearchValues.ContainsKey("searchOperator1")
        ? Model.SearchValues["searchOperator1"]
        : "contains";

    var searchValue1 = Model.SearchValues.ContainsKey("searchValue1")
        ? Model.SearchValues["searchValue1"]
        : "";

    var searchField2 = Model.SearchValues.ContainsKey("searchField2")
        ? Model.SearchValues["searchField2"]
        : "";

    var searchOperator2 = Model.SearchValues.ContainsKey("searchOperator2")
        ? Model.SearchValues["searchOperator2"]
        : "contains";

    var searchValue2 = Model.SearchValues.ContainsKey("searchValue2")
        ? Model.SearchValues["searchValue2"]
        : "";
}

<h1>@Model.ScreenName</h1>

@if (Model.ScreenMode != "Report")
{
    <a class="btn btn-primary mb-4"
       href="/Screen/@Model.ScreenCode/Create">
        + Create New
    </a>
}

<form method="get" class="border rounded p-4 mb-4">

    <div class="row mb-3 align-items-end">
        <div class="col-md-1 fw-bold">Filter 1</div>

        <div class="col-md-3">
            <label>Field</label>
            <select name="searchField1" class="form-control">
                <option value="">-- Select Field --</option>
                @foreach (var column in Model.Columns.Where(c => c.IsVisible))
                {
                    <option value="@column.FieldName" selected="@(searchField1 == column.FieldName)">
                        @column.DisplayLabel
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label>Operator</label>
            <select name="searchOperator1" class="form-control">
                <option value="contains" selected="@(searchOperator1 == "contains")">Contains</option>
                <option value="equals" selected="@(searchOperator1 == "equals")">Equals</option>
                <option value="starts" selected="@(searchOperator1 == "starts")">Starts With</option>
                <option value="ends" selected="@(searchOperator1 == "ends")">Ends With</option>
            </select>
        </div>

        <div class="col-md-4">
            <label>Value</label>
            <input name="searchValue1" value="@searchValue1" class="form-control" />
        </div>
    </div>

    <div class="row mb-3 align-items-end">
        <div class="col-md-1 fw-bold">Filter 2</div>

        <div class="col-md-3">
            <label>Field</label>
            <select name="searchField2" class="form-control">
                <option value="">-- Select Field --</option>
                @foreach (var column in Model.Columns.Where(c => c.IsVisible))
                {
                    <option value="@column.FieldName" selected="@(searchField2 == column.FieldName)">
                        @column.DisplayLabel
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label>Operator</label>
            <select name="searchOperator2" class="form-control">
                <option value="contains" selected="@(searchOperator2 == "contains")">Contains</option>
                <option value="equals" selected="@(searchOperator2 == "equals")">Equals</option>
                <option value="starts" selected="@(searchOperator2 == "starts")">Starts With</option>
                <option value="ends" selected="@(searchOperator2 == "ends")">Ends With</option>
            </select>
        </div>

        <div class="col-md-4">
            <label>Value</label>
            <input name="searchValue2" value="@searchValue2" class="form-control" />
        </div>
    </div>

    <div class="row mb-3 align-items-end">
        <div class="col-md-1 fw-bold">Sorting</div>

        <div class="col-md-3">
            <label>Sort By</label>
            <select name="sortColumn" class="form-control">
                <option value="">-- Default Sort --</option>
                @foreach (var column in Model.Columns.Where(c => c.IsVisible))
                {
                    <option value="@column.FieldName" selected="@(Model.SortColumn == column.FieldName)">
                        @column.DisplayLabel
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label>Direction</label>
            <select name="sortDirection" class="form-control">
                <option value="ASC" selected="@(Model.SortDirection == "ASC")">Ascending</option>
                <option value="DESC" selected="@(Model.SortDirection == "DESC")">Descending</option>
            </select>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Search</button>

    <a href="/Screen/@Model.ScreenCode" class="btn btn-secondary">Reset</a>

    <button type="submit"
            formaction="/Screen/@Model.ScreenCode/Export"
            class="btn btn-success">
        Export Excel
    </button>

</form>

<table class="table">
    <thead>
        <tr>
            @foreach (var column in Model.Columns.Where(c => c.IsVisible))
            {
                <th>@column.DisplayLabel</th>
            }

            @if (Model.ScreenMode != "Report")
            {
                <th>Actions</th>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                @foreach (var column in Model.Columns.Where(c => c.IsVisible))
                {
                    <td>
                        @{
                            var value = row.ContainsKey(column.FieldName)
                                ? row[column.FieldName]
                                : null;
                        }

                        @value
                    </td>
                }

                @if (Model.ScreenMode != "Report")
                {
                    <td>
                        <a class="btn btn-primary btn-sm"
                           href="/Screen/@Model.ScreenCode/Edit/@row["Id"]">
                            Edit
                        </a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
