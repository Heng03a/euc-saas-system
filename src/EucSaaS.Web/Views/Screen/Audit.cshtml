@model EucSaaS.Web.ViewModels.Dynamic.DynamicEditViewModel

@{
    ViewData["Title"] = "Audit Trail - " + Model.ScreenName;
}

<h2>Audit Trail - @Model.ScreenName</h2>

@if (!Model.AuditLogs.Any())
{
    <div class="alert alert-info">
        No audit records found.
    </div>
}
else
{
    <table class="table table-bordered table-sm">
        <thead>
            <tr>
                <th>Changed At</th>
                <th>Action</th>
                <th>Field</th>
                <th>Old Value</th>
                <th>New Value</th>
                <th>Changed By</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.AuditLogs)
            {
                <tr>
                    <td>@log.ChangedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@log.ActionType</td>
                    <td>@log.FieldName</td>
                    <td>@log.OldValue</td>
                    <td>@log.NewValue</td>
                    <td>@log.ChangedBy</td>
                </tr>
            }
        </tbody>
    </table>
}

<a class="btn btn-secondary" href="@(ViewBag.ReturnUrl ?? $"/Screen/{Model.ScreenCode}")">
    Back
</a>
