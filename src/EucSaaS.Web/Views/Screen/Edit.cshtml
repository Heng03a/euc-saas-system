@model EucSaaS.Web.ViewModels.Dynamic.DynamicEditViewModel

@{
    ViewData["Title"] = "Edit " + Model.ScreenName;
}

<h2>Edit @Model.ScreenName</h2>

<form method="post" action="/Screen/@Model.ScreenCode/Edit/@Model.RecordId">

<input type="hidden" name="Id" value="@Model.RecordId" />

<input type="hidden"
       name="returnUrl"
       value="@ViewBag.ReturnUrl" />

    @foreach (var field in Model.Fields)
    {
        var value = Model.Values
            .FirstOrDefault(x =>
                x.Key.Equals(
                    field.FieldName,
                    StringComparison.OrdinalIgnoreCase))
            .Value;

        var controlType = field.ControlType ?? "";

        <div class="form-group mb-3">
            <label>@field.DisplayLabel</label>

            @if (controlType.Equals("dropdown", StringComparison.OrdinalIgnoreCase)
                || controlType.Equals("select", StringComparison.OrdinalIgnoreCase))
            {
                <select class="form-control" name="@field.FieldName">
                    <option value="">-- Select --</option>

                    @foreach (var option in field.Options.OrderBy(x => x.DisplayOrder))
                    {
                        var isSelected =
                            value != null &&
                            option.OptionValue.Equals(
                                value.ToString(),
                                StringComparison.OrdinalIgnoreCase);

                        if (isSelected)
                        {
                            <option value="@option.OptionValue" selected="selected">
                                @option.OptionLabel
                            </option>
                        }
                        else
                        {
                            <option value="@option.OptionValue">
                                @option.OptionLabel
                            </option>
                        }
                    }
                </select>
            }
            else
            {
                <input class="form-control"
                       name="@field.FieldName"
                       value="@value" />
            }
        </div>
    }

<button type="submit" class="btn btn-primary">

    Save
</button>

<a href="@(ViewBag.ReturnUrl ?? $"/Screen/{Model.ScreenCode}")"
   class="btn btn-secondary">
    Back
</a>
</form>
