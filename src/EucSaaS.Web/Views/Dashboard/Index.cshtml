@model EucSaaS.Web.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard</h2>

<div id="dashboardFullscreenArea"
     class="dashboard-fullscreen-area">

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <form id="dashboardFilterForm"
                  method="get"
                  asp-controller="Dashboard"
                  asp-action="Index">

                <div class="row g-3 align-items-end">

                    <!-- Department -->

                    <div class="col-md-4">

                        <label class="form-label fw-semibold">
                            Department
                        </label>

                        <select id="departmentFilter"
                                name="department"
                                class="form-select">

                            <option value="">
                                All Departments
                            </option>

                            @foreach (var dept in Model.Filter.Departments)
                            {
                                <option value="@dept"
                                        selected="@(Model.Filter.Department == dept)">
                                    @dept
                                </option>
                            }

                        </select>

                    </div>

                    <!-- Status -->

                    <div class="col-md-4">

                        <label class="form-label fw-semibold">
                            Status
                        </label>

                        <select id="statusFilter"
                                name="status"
                                class="form-select">

                            <option value="">
                                All Statuses
                            </option>

                            @foreach (var status in Model.Filter.Statuses)
                            {
                                <option value="@status"
                                        selected="@(Model.Filter.Status == status)">
                                    @status
                                </option>
                            }

                        </select>

                    </div>

                    <!-- Buttons -->

                    <div class="col-md-4">

                        <label class="form-label fw-semibold">

                            Auto Refresh

                        </label>

                        <div class="d-flex gap-2 flex-wrap">

                            <select id="autoRefreshInterval"
                                    class="form-select"
                                    style="max-width:180px;">

                                <option value="0">
                                    Off
                                </option>

                                <option value="30">
                                    30 Seconds
                                </option>

                                <option value="60">
                                    1 Minute
                                </option>

                                <option value="300">
                                    5 Minutes
                                </option>

                                <option value="600">
                                    10 Minutes
                                </option>

                            </select>

                            <!-- Refresh -->

                            <button id="refreshDashboardButton"
                                    type="submit"
                                    class="btn btn-primary"
                                    title="Refresh Dashboard">

                                <i class="bi bi-arrow-clockwise"></i>

                            </button>

                            <!-- Clear -->

                            <button id="clearDashboardButton"
                                    type="button"
                                    class="btn btn-outline-secondary">

                                Clear

                            </button>

                            <!-- Fullscreen -->

                            <button id="fullscreenDashboardButton"
                                    type="button"
                                    class="btn btn-outline-dark"
                                    title="Fullscreen">

                                <i id="fullscreenDashboardIcon"
                                   class="bi bi-arrows-fullscreen"></i>

                            </button>

                            <!-- Export Excel -->

                            <a id="exportExcelButton"
                               class="btn btn-success"
                               href="#"
                               title="Export Dashboard to Excel">

                                <i class="bi bi-file-earmark-excel"></i>

                                Export

                            </a>

                        </div>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">

        <div>

            <span class="badge bg-success">

                Dashboard Ready

            </span>

        </div>

        <small class="text-muted">

            Last Refreshed :

            <span id="lastRefreshedTime">

                @DateTime.Now.ToString("dd MMM yyyy HH:mm:ss")

            </span>

        </small>

    </div>

    <div id="dashboardLoading"
         class="text-center my-5"
         style="display:none;">

        <div class="spinner-border text-primary">

        </div>

        <div class="mt-2">

            Loading dashboard...

        </div>

    </div>

    <div id="dashboardError"
         class="alert alert-danger"
         style="display:none;">

        Dashboard could not be refreshed.

    </div>

    <div id="dashboardContent">

        <partial name="_DashboardContent"
                 model="Model" />

    </div>

</div>

<style>

.dashboard-fullscreen-area:fullscreen{

    background:var(--bs-body-bg);

    padding:24px;

    overflow:auto;

}

.dashboard-fullscreen-area:-webkit-full-screen{

    background:var(--bs-body-bg);

    padding:24px;

    overflow:auto;

}

</style>

@section Scripts
{
    <script>
        $(document).ready(function () {

            const filterForm =
                $("#dashboardFilterForm");

            const departmentFilter =
                $("#departmentFilter");

            const statusFilter =
                $("#statusFilter");

            const dashboardContent =
                $("#dashboardContent");

            const dashboardLoading =
                $("#dashboardLoading");

            const dashboardError =
                $("#dashboardError");

            const refreshButton =
                $("#refreshDashboardButton");

            const clearButton =
                $("#clearDashboardButton");

            const autoRefreshInterval =
                $("#autoRefreshInterval");

            const lastRefreshedTime =
                $("#lastRefreshedTime");

            const exportExcelButton =
                $("#exportExcelButton");

            const fullscreenButton =
                $("#fullscreenDashboardButton");

            const fullscreenIcon =
                $("#fullscreenDashboardIcon");

            const fullscreenArea =
                document.getElementById(
                    "dashboardFullscreenArea"
                );

            let autoRefreshTimer = null;

            function updateLastRefreshedTime() {

                const now =
                    new Date();

                const formattedTime =
                    now.toLocaleString(
                        "en-SG",
                        {
                            day: "2-digit",
                            month: "short",
                            year: "numeric",
                            hour: "2-digit",
                            minute: "2-digit",
                            second: "2-digit",
                            hour12: false
                        }
                    );

                lastRefreshedTime.text(
                    formattedTime
                );
            }

            function updateExportUrl() {

                const department =
                    departmentFilter.val() || "";

                const status =
                    statusFilter.val() || "";

                const exportUrl =
                    "@Url.Action("ExportExcel", "Dashboard")"
                    + "?department="
                    + encodeURIComponent(
                        department
                    )
                    + "&status="
                    + encodeURIComponent(
                        status
                    );

                exportExcelButton.attr(
                    "href",
                    exportUrl
                );
            }

            function refreshDashboard() {

                const department =
                    departmentFilter.val() || "";

                const status =
                    statusFilter.val() || "";

                dashboardError.hide();

                dashboardLoading.show();

                dashboardContent.css(
                    "opacity",
                    "0.4"
                );

                refreshButton.prop(
                    "disabled",
                    true
                );

                clearButton.prop(
                    "disabled",
                    true
                );

                autoRefreshInterval.prop(
                    "disabled",
                    true
                );

                exportExcelButton.addClass(
                    "disabled"
                );

                $.ajax({
                    url:
                        "@Url.Action("Refresh", "Dashboard")",

                    type:
                        "GET",

                    data: {
                        department:
                            department,

                        status:
                            status
                    },

                    cache:
                        false,

                    success:
                        function (html) {

                            dashboardContent.html(
                                html
                            );

                            updateBrowserUrl(
                                department,
                                status
                            );

                            updateExportUrl();

                            updateLastRefreshedTime();
                        },

                    error:
                        function (xhr) {

                            console.error(
                                "Dashboard refresh failed:",
                                xhr.responseText
                            );

                            dashboardError.show();
                        },

                    complete:
                        function () {

                            dashboardLoading.hide();

                            dashboardContent.css(
                                "opacity",
                                "1"
                            );

                            refreshButton.prop(
                                "disabled",
                                false
                            );

                            clearButton.prop(
                                "disabled",
                                false
                            );

                            autoRefreshInterval.prop(
                                "disabled",
                                false
                            );

                            exportExcelButton.removeClass(
                                "disabled"
                            );
                        }
                });
            }

            function updateBrowserUrl(
                department,
                status) {

                const queryString =
                    new URLSearchParams();

                if (department) {

                    queryString.set(
                        "department",
                        department
                    );
                }

                if (status) {

                    queryString.set(
                        "status",
                        status
                    );
                }

                let newUrl =
                    "@Url.Action("Index", "Dashboard")";

                const query =
                    queryString.toString();

                if (query) {

                    newUrl +=
                        "?" + query;
                }

                window.history.replaceState(
                    {},
                    "",
                    newUrl
                );
            }

            function stopAutoRefresh() {

                if (
                    autoRefreshTimer !== null
                ) {

                    clearInterval(
                        autoRefreshTimer
                    );

                    autoRefreshTimer =
                        null;
                }
            }

            function startAutoRefresh() {

                stopAutoRefresh();

                const intervalSeconds =
                    parseInt(
                        autoRefreshInterval.val(),
                        10
                    );

                if (
                    !intervalSeconds ||
                    intervalSeconds <= 0
                ) {

                    return;
                }

                autoRefreshTimer =
                    setInterval(
                        function () {

                            refreshDashboard();

                        },
                        intervalSeconds * 1000
                    );
            }

            function isDashboardFullscreen() {

                return (
                    document.fullscreenElement ===
                    fullscreenArea
                ) ||
                (
                    document.webkitFullscreenElement ===
                    fullscreenArea
                );
            }

            function updateFullscreenButton() {

                if (
                    isDashboardFullscreen()
                ) {

                    fullscreenIcon
                        .removeClass(
                            "bi-arrows-fullscreen"
                        )
                        .addClass(
                            "bi-fullscreen-exit"
                        );

                    fullscreenButton.attr(
                        "title",
                        "Exit fullscreen"
                    );
                }
                else {

                    fullscreenIcon
                        .removeClass(
                            "bi-fullscreen-exit"
                        )
                        .addClass(
                            "bi-arrows-fullscreen"
                        );

                    fullscreenButton.attr(
                        "title",
                        "Open dashboard in fullscreen"
                    );
                }
            }

            async function toggleDashboardFullscreen() {

                try {

                    if (
                        !isDashboardFullscreen()
                    ) {

                        if (
                            fullscreenArea.requestFullscreen
                        ) {

                            await fullscreenArea
                                .requestFullscreen();
                        }
                        else if (
                            fullscreenArea
                                .webkitRequestFullscreen
                        ) {

                            fullscreenArea
                                .webkitRequestFullscreen();
                        }
                    }
                    else {

                        if (
                            document.exitFullscreen
                        ) {

                            await document
                                .exitFullscreen();
                        }
                        else if (
                            document
                                .webkitExitFullscreen
                        ) {

                            document
                                .webkitExitFullscreen();
                        }
                    }
                }
                catch (error) {

                    console.error(
                        "Fullscreen operation failed:",
                        error
                    );

                    alert(
                        "Fullscreen mode is not available in this browser."
                    );
                }
            }

fullscreenButton.on(
    "click",
    function () {

        toggleDashboardFullscreen();
    }
);
            filterForm.on(
                "submit",
                function (event) {

                    event.preventDefault();

                    refreshDashboard();
                }
            );

            departmentFilter.on(
                "change",
                function () {

                    refreshDashboard();
                }
            );

            statusFilter.on(
                "change",
                function () {

                    refreshDashboard();
                }
            );

            autoRefreshInterval.on(
                "change",
                function () {

                    startAutoRefresh();
                }
            );

            clearButton.on(
                "click",
                function () {

                    departmentFilter.val("");
                    statusFilter.val("");

                    updateExportUrl();

                    refreshDashboard();
                }
            );

            fullscreenButton.on(
                "click",
                function () {

                    toggleDashboardFullscreen();
                }
            );

            document.addEventListener(
                "fullscreenchange",
                function () {

                    updateFullscreenButton();
                }
            );

            document.addEventListener(
                "webkitfullscreenchange",
                function () {

                    updateFullscreenButton();
                }
            );

            /*
             * Widget-level AJAX refresh.
             * Event delegation is required because widgets
             * are dynamically replaced after AJAX requests.
             */
            $(document).on(
                "click",
                ".refresh-widget-button",
                function () {

                    const button =
                        $(this);

                    const widgetId =
                        button.attr(
                            "data-widget-id"
                        );

                    if (!widgetId) {

                        console.error(
                            "Widget ID is missing."
                        );

                        return;
                    }

                    const widgetContainer =
                        $("#dashboardWidget_" + widgetId);

                    if (widgetContainer.length === 0) {

                        console.error(
                            "Widget container was not found:",
                            widgetId
                        );

                        return;
                    }

                    const department =
                        departmentFilter.val() || "";

                    const status =
                        statusFilter.val() || "";

                    const originalButtonHtml =
                        button.html();

                    button.prop(
                        "disabled",
                        true
                    );

                    button.html(
                        '<span class="spinner-border ' +
                        'spinner-border-sm" ' +
                        'role="status" ' +
                        'aria-hidden="true"></span>'
                    );

                    widgetContainer.css(
                        "opacity",
                        "0.45"
                    );

                    $.ajax({
                        url:
                            "@Url.Action("RefreshWidget", "Dashboard")",

                        type:
                            "GET",

                        data: {
                            id:
                                widgetId,

                            department:
                                department,

                            status:
                                status
                        },

                        cache:
                            false,

                        success:
                            function (html) {

                                widgetContainer.replaceWith(
                                    html
                                );

                                updateLastRefreshedTime();
                            },

                        error:
                            function (xhr) {

                                console.error(
                                    "Widget refresh failed:",
                                    xhr.responseText
                                );

                                widgetContainer.css(
                                    "opacity",
                                    "1"
                                );

                                button.prop(
                                    "disabled",
                                    false
                                );

                                button.html(
                                    originalButtonHtml
                                );

                                alert(
                                    "The widget could not be refreshed."
                                );
                            },

                        complete:
                            function () {

                                const currentContainer =
                                    $("#dashboardWidget_" + widgetId);

                                if (
                                    currentContainer.length === 0
                                ) {

                                    return;
                                }

                                currentContainer.css(
                                    "opacity",
                                    "1"
                                );

                                const currentButton =
                                    currentContainer.find(
                                        ".refresh-widget-button"
                                    );

                                currentButton.prop(
                                    "disabled",
                                    false
                                );
                            }
                    });
                }
            );

            /*
             * Prevent export when the button is temporarily disabled.
             */
            exportExcelButton.on(
                "click",
                function (event) {

                    if (
                        exportExcelButton.hasClass(
                            "disabled"
                        )
                    ) {

                        event.preventDefault();
                    }
                }
            );

            /*
             * Stop auto refresh when leaving the page.
             */
            $(window).on(
                "beforeunload",
                function () {

                    stopAutoRefresh();
                }
            );

            /*
             * Initial setup.
             */
            updateExportUrl();

            updateFullscreenButton();
        });
    </script>
}

