@model EucSaaS.Web.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard</h2>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">

        <form id="dashboardFilterForm"
              method="get"
              asp-controller="Dashboard"
              asp-action="Index">

            <div class="row g-3 align-items-end">

                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        Department
                    </label>

                    <select id="departmentFilter"
                            name="department"
                            class="form-select">

                        <option value="">All Departments</option>

                        @foreach (var dept in Model.Filter.Departments)
                        {
                            <option value="@dept"
                                    selected="@(Model.Filter.Department == dept)">
                                @dept
                            </option>
                        }

                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        Status
                    </label>

                    <select id="statusFilter"
                            name="status"
                            class="form-select">

                        <option value="">All Statuses</option>

                        @foreach (var status in Model.Filter.Statuses)
                        {
                            <option value="@status"
                                    selected="@(Model.Filter.Status == status)">
                                @status
                            </option>
                        }

                    </select>
                </div>

                <div class="col-md-4 d-flex gap-2">

                    <button id="refreshDashboardButton"
                            type="submit"
                            class="btn btn-primary">

                        <i class="bi bi-arrow-clockwise me-1"></i>
                        Refresh
                    </button>

                    <button id="clearDashboardButton"
                            type="button"
                            class="btn btn-outline-secondary">

                        Clear
                    </button>

                </div>

            </div>
        </form>
    </div>
</div>

<div id="dashboardLoading"
     class="text-center my-5"
     style="display:none;">

    <div class="spinner-border text-primary"
         role="status">

        <span class="visually-hidden">
            Loading...
        </span>
    </div>

    <div class="mt-2 text-muted">
        Loading dashboard...
    </div>
</div>

<div id="dashboardError"
     class="alert alert-danger"
     style="display:none;">

    Dashboard could not be refreshed. Please try again.
</div>

<div id="dashboardContent">
    <partial name="_DashboardContent" model="Model" />
</div>

@section Scripts
{
    <script>
        $(document).ready(function () {

            const filterForm = $("#dashboardFilterForm");
            const departmentFilter = $("#departmentFilter");
            const statusFilter = $("#statusFilter");

            const dashboardContent = $("#dashboardContent");
            const dashboardLoading = $("#dashboardLoading");
            const dashboardError = $("#dashboardError");

            const refreshButton = $("#refreshDashboardButton");
            const clearButton = $("#clearDashboardButton");

            function refreshDashboard() {

                const department =
                    departmentFilter.val() || "";

                const status =
                    statusFilter.val() || "";

                dashboardError.hide();
                dashboardLoading.show();

                dashboardContent.css(
                    "opacity",
                    "0.4"
                );

                refreshButton.prop(
                    "disabled",
                    true
                );

                clearButton.prop(
                    "disabled",
                    true
                );

                $.ajax({
                    url: "@Url.Action("Refresh", "Dashboard")",

                    type: "GET",

                    data: {
                        department: department,
                        status: status
                    },

                    cache: false,

                    success: function (html) {

                        dashboardContent.html(html);

                        updateBrowserUrl(
                            department,
                            status
                        );
                    },

                    error: function (xhr) {

                        console.error(
                            "Dashboard refresh failed:",
                            xhr.responseText
                        );

                        dashboardError.show();
                    },

                    complete: function () {

                        dashboardLoading.hide();

                        dashboardContent.css(
                            "opacity",
                            "1"
                        );

                        refreshButton.prop(
                            "disabled",
                            false
                        );

                        clearButton.prop(
                            "disabled",
                            false
                        );
                    }
                });
            }

            function updateBrowserUrl(
                department,
                status) {

                const queryString =
                    new URLSearchParams();

                if (department) {

                    queryString.set(
                        "department",
                        department
                    );
                }

                if (status) {

                    queryString.set(
                        "status",
                        status
                    );
                }

                let newUrl =
                    "@Url.Action("Index", "Dashboard")";

                const query =
                    queryString.toString();

                if (query) {

                    newUrl +=
                        "?" + query;
                }

                window.history.replaceState(
                    {},
                    "",
                    newUrl
                );
            }

            filterForm.on(
                "submit",
                function (event) {

                    event.preventDefault();

                    refreshDashboard();
                }
            );

            departmentFilter.on(
                "change",
                function () {

                    refreshDashboard();
                }
            );

            statusFilter.on(
                "change",
                function () {

                    refreshDashboard();
                }
            );

            clearButton.on(
                "click",
                function () {

                    departmentFilter.val("");
                    statusFilter.val("");

                    refreshDashboard();
                }
            );

            /*
             * Widget-level AJAX refresh.
             *
             * Event delegation is required because widgets are
             * dynamically replaced after an AJAX refresh.
             */
            $(document).on(
                "click",
                ".refresh-widget-button",
                function () {

                    const button = $(this);

                    const widgetId =
                        button.attr("data-widget-id");

                    if (!widgetId) {

                        console.error(
                            "Widget ID is missing."
                        );

                        return;
                    }

                    const widgetContainer =
                        $("#dashboardWidget_" + widgetId);

                    if (widgetContainer.length === 0) {

                        console.error(
                            "Widget container was not found:",
                            widgetId
                        );

                        return;
                    }

                    const department =
                        departmentFilter.val() || "";

                    const status =
                        statusFilter.val() || "";

                    const originalButtonHtml =
                        button.html();

                    button.prop(
                        "disabled",
                        true
                    );

                    button.html(
                        '<span class="spinner-border ' +
                        'spinner-border-sm" ' +
                        'role="status" ' +
                        'aria-hidden="true"></span>'
                    );

                    widgetContainer.css(
                        "opacity",
                        "0.45"
                    );

                    $.ajax({
                        url: "@Url.Action("RefreshWidget", "Dashboard")",

                        type: "GET",

                        data: {
                            id: widgetId,
                            department: department,
                            status: status
                        },

                        cache: false,

                        success: function (html) {

                            widgetContainer.replaceWith(
                                html
                            );
                        },

                        error: function (xhr) {

                            console.error(
                                "Widget refresh failed:",
                                xhr.responseText
                            );

                            widgetContainer.css(
                                "opacity",
                                "1"
                            );

                            button.prop(
                                "disabled",
                                false
                            );

                            button.html(
                                originalButtonHtml
                            );

                            alert(
                                "The widget could not be refreshed."
                            );
                        },

                        complete: function () {

                            const currentContainer =
                                $("#dashboardWidget_" + widgetId);

                            if (currentContainer.length === 0) {
                                return;
                            }

                            currentContainer.css(
                                "opacity",
                                "1"
                            );

                            const currentButton =
                                currentContainer.find(
                                    ".refresh-widget-button"
                                );

                            currentButton.prop(
                                "disabled",
                                false
                            );
                        }
                    });
                }
            );
        });
    </script>
}
