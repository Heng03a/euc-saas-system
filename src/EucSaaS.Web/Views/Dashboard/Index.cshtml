@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/admin.css" />

<div class="admin-wrapper">
    <aside class="admin-sidebar">
        <div class="admin-logo">EUC SaaS</div>

        <nav class="admin-menu">
            @await Component.InvokeAsync("SidebarMenu")
        </nav>
    </aside>

    <main class="admin-main">
        <button class="mobile-menu-button" onclick="document.body.classList.toggle('sidebar-open')">
            ☰ Menu
        </button>
        <header class="admin-topbar">
            <div>
                <strong>Admin Dashboard</strong><br />
                <span>Welcome, @User.FindFirst("FullName")?.Value</span>
            </div>

            <a class="logout-link" asp-controller="Auth" asp-action="Logout">Logout</a>
        </header>

        <section class="admin-content">
            <h2>Dashboard Overview</h2>

            <div class="dashboard-grid">
                <div class="dashboard-card">
                    <h3>Users</h3>
                    <p>1</p>
                </div>

                <div class="dashboard-card">
                    <h3>Roles</h3>
                    <p>1</p>
                </div>

                <div class="dashboard-card">
                    <h3>Menus</h3>
                    <p>3</p>
                </div>
            </div>
        </section>
    </main>
</div>
