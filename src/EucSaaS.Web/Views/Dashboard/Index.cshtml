@model EucSaaS.Web.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Dashboard</h2>

@if (Model.Widgets == null || !Model.Widgets.Any())
{
    <div class="alert alert-info">
        No dashboard widgets configured.
    </div>
}
else
{
    <div class="row">
        @foreach (var widget in Model.Widgets.OrderBy(x => x.DisplayOrder))
        {
            if (widget.WidgetType.Equals("Card", StringComparison.OrdinalIgnoreCase))
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <div class="text-muted small">
                                @widget.WidgetTitle
                            </div>

                            <div class="fs-2 fw-bold">
                                @widget.Value
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}
