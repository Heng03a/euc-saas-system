@model EucSaaS.Web.ViewModels.Admin.AdminListViewModel

@if (TempData["SuccessMessage"] != null)
{
    <div style="background:#dcfce7;
                color:#166534;
                padding:12px 16px;
                border-radius:8px;
                margin-bottom:16px;
                border:1px solid #86efac;">
        @TempData["SuccessMessage"]
    </div>
}

@{
    ViewData["Title"] = Model.ScreenName;
}

<link rel="stylesheet" href="~/css/admin.css" />

<div class="admin-page">

    <div class="admin-header">

        <h2>@Model.ScreenName</h2>

        <a class="btn-add"
           href="/admin/@Model.ScreenCode/create">
            + Add New
        </a>

    </div>

    <form method="get" class="filter-bar">

        <select name="filterField">
            <option value="">Field</option>

            @foreach (var column in Model.Columns)
            {
                if (Model.FilterField == column)
                {
                    <option value="@column" selected>@column</option>
                }
                else
                {
                    <option value="@column">@column</option>
                }
            }
        </select>

        <select name="filterOperator">
            <option value="contains" selected="@(Model.FilterOperator == "contains")">Contains</option>
            <option value="equals" selected="@(Model.FilterOperator == "equals")">Equals</option>
            <option value="startsWith" selected="@(Model.FilterOperator == "startsWith")">Starts With</option>
            <option value="endsWith" selected="@(Model.FilterOperator == "endsWith")">Ends With</option>
        </select>

        <input type="text"
               name="filterValue"
               value="@Model.FilterValue"
               placeholder="Filter Value..." />

        <button type="submit">
            Search
        </button>

    </form>

    <div class="table-responsive">
    <table class="admin-table">

        <thead>
            <tr>
                @foreach (var column in Model.Columns)
                {
                    var nextDir = Model.SortDir == "asc" ? "desc" : "asc";

                    <th>
                        <a href="?sortBy=@column&sortDir=@nextDir&filterField=@Model.FilterField&filterOperator=@Model.FilterOperator&filterValue=@Model.FilterValue">
                            @column
                        </a>
                    </th>
                }

                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @if (Model.Rows.Count == 0)
            {
                <tr>
                    <td colspan="@(Model.Columns.Count + 1)">
                        No records found.
                    </td>
                </tr>
            }

            @foreach (var row in Model.Rows)
            {
                <tr>
                    @foreach (var column in Model.Columns)
                    {
                        <td>
                            @row[column]
                        </td>
                    }

    @* ===== View Button only on List screen ===== *@
<td class="action-cell">

    <a class="btn-secondary"
       href="/admin/@Model.ScreenCode/details/@row["__Id"]">
        View
    </a>


</td>
                </tr>
            }

        </tbody>

    </table>
    </div>

    <div class="paging">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            var activeClass = Model.Page == i ? "page-link active-page" : "page-link";

            <a class="@activeClass"
               href="?page=@i&filterField=@Model.FilterField&filterOperator=@Model.FilterOperator&filterValue=@Model.FilterValue&sortBy=@Model.SortBy&sortDir=@Model.SortDir">
                @i
            </a>
        }

    </div>

</div>
