@model EucSaaS.Domain.Entities.Employee

@{
    ViewData["Title"] = "Delete Employee";
    var screenCode = ViewBag.ScreenCode as string ?? "EMPLOYEES";
}

<link rel="stylesheet" href="~/css/admin.css" />

<div class="admin-page">
    <h2>Delete Employee</h2>

    <div class="alert alert-danger">
        Are you sure you want to delete this employee?
    </div>

    <div class="admin-details">
        <div class="detail-row">
            <strong>Employee Code:</strong>
            <span>@Model.EmployeeCode</span>
        </div>

        <div class="detail-row">
            <strong>Full Name:</strong>
            <span>@Model.FullName</span>
        </div>

        <div class="detail-row">
            <strong>Email:</strong>
            <span>@Model.Email</span>
        </div>

        <div class="detail-row">
            <strong>Department:</strong>
            <span>@Model.Department</span>
        </div>

        <div class="detail-row">
            <strong>Status:</strong>
            <span>@Model.Status</span>
        </div>
    </div>

    <form method="post" asp-action="DeleteConfirmed" asp-route-screenCode="@screenCode" asp-route-id="@Model.Id">
        @Html.AntiForgeryToken()

        <div class="form-actions">
            <button type="submit" class="btn-danger">Yes, Delete</button>
            <a href="/admin/@screenCode" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>