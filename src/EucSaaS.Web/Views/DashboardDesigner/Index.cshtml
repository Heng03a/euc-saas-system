@model List<EucSaaS.Web.ViewModels.Dashboard.DashboardWidgetDefinitionViewModel>

@{
    ViewData["Title"] = "Dashboard Designer";
}

<h2>Dashboard Designer</h2>

<p class="text-muted">
    Drag widgets by using the handle icon to reorder dashboard layout.
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div id="saveMessage" class="alert alert-success d-none"></div>

<div class="mb-3">
    <button type="button" id="saveLayoutBtn" class="btn btn-primary">
        Save Layout
    </button>

    <a asp-action="Create" class="btn btn-success">
        Create Widget
    </a>
</div>

@Html.AntiForgeryToken()

<div id="dashboardDesignerList" class="row g-3">

@foreach (var widget in Model
    .OrderBy(x => x.RowPosition)
    .ThenBy(x => x.ColumnPosition)
    .ThenBy(x => x.DisplayOrder))
{
    var width = widget.WidgetWidth <= 0 ? 4 : widget.WidgetWidth;
    var height = widget.Height <= 0 ? 300 : widget.Height;

    <div class="col-md-@width dashboard-widget-item"
         data-widget-id="@widget.Id"
         data-row-position="@widget.RowPosition"
         data-column-position="@widget.ColumnPosition"
         data-widget-width="@width"
         data-height="@height">

        <div class="card shadow-sm h-100">

            <div class="card-header bg-light d-flex justify-content-between align-items-center">

                <div class="d-flex align-items-center">

                    <span class="drag-handle me-2"
                          title="Drag widget">
                        ☰
                    </span>

                    <strong>@widget.WidgetCode</strong>

                </div>

                <span class="badge bg-secondary">
                    Drag
                </span>

            </div>

            <div class="card-body">
                <p class="mb-1">
                    <strong>Code:</strong> @widget.WidgetCode
                </p>

                <p class="mb-1">
                    <strong>Type:</strong> @widget.WidgetType
                </p>

                <p class="mb-1">
                    <strong>Width:</strong> @widget.WidgetWidth
                </p>

                <p class="mb-1">
                    <strong>Row:</strong> @widget.RowPosition
                </p>

                <p class="mb-1">
                    <strong>Column:</strong> @widget.ColumnPosition
                </p>

                <p class="mb-1">
                    <strong>Height:</strong> @widget.Height
                </p>

                <p class="mb-1">
                    <strong>Order:</strong> @widget.DisplayOrder
                </p>

                <p class="mb-0">
                    <strong>Active:</strong> @(widget.IsActive ? "Yes" : "No")
                </p>
            </div>

            <div class="card-footer text-end">
                <a asp-action="Edit"
                   asp-route-id="@widget.Id"
                   class="btn btn-sm btn-primary">
                    Edit
                </a>

                <a asp-action="Clone"
                   asp-route-id="@widget.Id"
                   class="btn btn-sm btn-warning">
                    Clone
                </a>

                <a asp-action="Delete"
                   asp-route-id="@widget.Id"
                   class="btn btn-sm btn-danger">
                    Delete
                </a>
            </div>

        </div>
    </div>
}

</div>

<style>
    .drag-handle {
        cursor: grab;
        user-select: none;
        font-size: 22px;
        line-height: 1;
        color: #6c757d;
    }

    .drag-handle:active {
        cursor: grabbing;
    }

    .dashboard-widget-item.sortable-chosen .card {
        border: 2px solid #0d6efd;
    }

    .dashboard-widget-item.sortable-ghost {
        opacity: 0.5;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>

    <script>
        const designerList = document.getElementById("dashboardDesignerList");
        const saveButton = document.getElementById("saveLayoutBtn");
        const messageBox = document.getElementById("saveMessage");

        saveButton.disabled = true;

        new Sortable(designerList, {
            animation: 150,
            handle: ".drag-handle",
            ghostClass: "sortable-ghost",
            chosenClass: "sortable-chosen",
            dragClass: "shadow-lg",

            onEnd: function () {
                saveButton.disabled = false;

                messageBox.innerText = "Layout has unsaved changes.";
                messageBox.classList.remove("d-none", "alert-success");
                messageBox.classList.add("alert-warning");
            }
        });

        saveButton.addEventListener("click", function () {

            const widgets = document.querySelectorAll(".dashboard-widget-item");
            const layoutItems = [];

            widgets.forEach(function (item, index) {

                layoutItems.push({
                    widgetId: item.getAttribute("data-widget-id"),
                    rowPosition: 1,
                    columnPosition: index + 1,
                    widgetWidth: parseInt(item.getAttribute("data-widget-width")) || 4,
                    height: parseInt(item.getAttribute("data-height")) || 300,
                    displayOrder: index + 1
                });

            });

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch("/DashboardDesigner/SaveLayout", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": token
                },
                body: JSON.stringify(layoutItems)
            })
            .then(async response => {
                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(errorText || "Save layout failed.");
                }

                return response.json();
            })
            .then(data => {
                messageBox.innerText = data.message;
                messageBox.classList.remove("d-none", "alert-warning");
                messageBox.classList.add("alert-success");

                saveButton.disabled = true;

                setTimeout(function () {
                    window.location.reload();
                }, 800);
            })
            .catch(error => {
                alert(error.message);
            });
        });
    </script>
}
