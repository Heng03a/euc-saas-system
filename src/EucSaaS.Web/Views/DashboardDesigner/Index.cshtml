@model List<EucSaaS.Web.ViewModels.Dashboard.DashboardWidgetDefinitionViewModel>

@{
    ViewData["Title"] = "Dashboard Designer";
}

<h2>Dashboard Designer</h2>

<p class="text-muted">
    Drag widgets to reorder dashboard layout.
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div id="saveMessage" class="alert alert-success d-none"></div>

<div class="mb-3">
    <button type="button" id="saveLayoutBtn" class="btn btn-primary">
        Save Layout
    </button>

    <a asp-action="Create" class="btn btn-success">
        Create Widget
    </a>
</div>

@Html.AntiForgeryToken()

<div id="dashboardDesignerList" class="row g-3">

@foreach (var widget in Model.OrderBy(x => x.DisplayOrder))
{
    <div class="col-md-4 dashboard-widget-item"
         data-widget-id="@widget.Id">

        <div class="card shadow-sm h-100">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
<strong>@widget.WidgetCode</strong>
                <span class="badge bg-secondary">Drag</span>
            </div>

            <div class="card-body">
                <p class="mb-1">
                    <strong>Code:</strong> @widget.WidgetCode
                </p>

                <p class="mb-1">
                    <strong>Type:</strong> @widget.WidgetType
                </p>

                <p class="mb-1">
                    <strong>Width:</strong> @widget.WidgetWidth
                </p>

                <p class="mb-1">
                    <strong>Order:</strong> @widget.DisplayOrder
                </p>

                <p class="mb-0">
                    <strong>Active:</strong> @(widget.IsActive ? "Yes" : "No")
                </p>
            </div>

            <div class="card-footer text-end">
                <a asp-action="Edit"
                   asp-route-id="@widget.Id"
                   class="btn btn-sm btn-primary">
                    Edit
                </a>

                <a asp-action="Clone"
                   asp-route-id="@widget.Id"
                   class="btn btn-sm btn-warning">
                    Clone
                </a>

                <a asp-action="Delete"
                   asp-route-id="@widget.Id"
                   class="btn btn-sm btn-danger">
                    Delete
                </a>
            </div>
        </div>
    </div>
}

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>

    <script>
        const designerList = document.getElementById("dashboardDesignerList");

        new Sortable(designerList, {
            animation: 150,
            ghostClass: "bg-warning"
        });

        document.getElementById("saveLayoutBtn").addEventListener("click", function () {

            const widgets = document.querySelectorAll(".dashboard-widget-item");

            const layoutItems = [];

            widgets.forEach(function (item, index) {
                layoutItems.push({
                    id: item.getAttribute("data-widget-id"),
                    displayOrder: index + 1
                });
            });

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch("/DashboardDesigner/SaveLayout", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": token
                },
                body: JSON.stringify(layoutItems)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error("Save layout failed.");
                }

                return response.json();
            })
  .then(data => {
    const messageBox = document.getElementById("saveMessage");
    messageBox.innerText = data.message;
    messageBox.classList.remove("d-none");

    setTimeout(function () {
        window.location.reload();
    }, 800);
})

            .catch(error => {
                alert(error.message);
            });
        });
    </script>
}
