@{
    ViewData["Title"] = "Employee List";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 id="screenTitle">Employees</h2>
            <p class="text-muted mb-0">Metadata-driven DataGrid + Dynamic Form + PostgreSQL CRUD</p>
        </div>

        <div>
            <button id="addBtn" class="btn btn-primary d-none">Add</button>
            <button id="exportBtn" class="btn btn-outline-secondary d-none">Export</button>
        </div>
    </div>

    <div class="mb-3">
        <input id="searchBox"
               type="text"
               class="form-control"
               placeholder="Search employee..."
               style="max-width: 350px;" />
    </div>

    <div id="dynamicFormPanel" class="card mb-4 d-none">
        <div class="card-header bg-dark text-white">
            <strong id="formTitle">Add Employee</strong>
        </div>

        <div class="card-body">
            <form id="dynamicForm">
                <div id="formFields" class="row"></div>

                <div class="mt-3">
                    <button type="submit" id="saveBtn" class="btn btn-success">Save</button>
                    <button type="button" id="cancelBtn" class="btn btn-secondary">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr id="gridHeader"></tr>
            </thead>
            <tbody id="gridBody"></tbody>
        </table>
    </div>

</div>

@section Scripts {
    <script>
        let metadata = null;
        let currentSortField = null;
        let currentSortDirection = "asc";
        let editIndex = null;
        let employees = [];

        document.addEventListener("DOMContentLoaded", async function () {
            await loadMetadata();

            document.getElementById("addBtn").addEventListener("click", openAddForm);
            document.getElementById("cancelBtn").addEventListener("click", closeForm);
            document.getElementById("dynamicForm").addEventListener("submit", saveForm);
            document.getElementById("searchBox").addEventListener("input", searchGrid);
        });

        async function loadMetadata() {
            const response = await fetch("/api/screens/employees/metadata");

            if (!response.ok) {
                alert("Unable to load metadata. Status: " + response.status);
                return;
            }

            metadata = await response.json();

            metadata.permission = {
                canAdd: true,
                canEdit: true,
                canDelete: true,
                canExport: true
            };

            document.getElementById("screenTitle").innerText = metadata.screen.screenName;

            applyPermissions(metadata.permission);

            await loadEmployees();
        }

        async function loadEmployees() {
            const response = await fetch("/api/employees");

            if (!response.ok) {
                alert("Unable to load employees.");
                return;
            }

            employees = await response.json();
            renderGrid(employees);
        }

        function applyPermissions(permission) {
            if (permission.canAdd) {
                document.getElementById("addBtn").classList.remove("d-none");
            }

            if (permission.canExport) {
                document.getElementById("exportBtn").classList.remove("d-none");
            }
        }

        function renderGrid(data) {
            renderHeader();
            renderRows(data);
        }

        function renderHeader() {
            const header = document.getElementById("gridHeader");
            header.innerHTML = "";

            metadata.columns.forEach(column => {
                const th = document.createElement("th");
                th.innerText = column.displayLabel;

                if (column.isSortable) {
                    th.style.cursor = "pointer";
                    th.title = "Click to sort";
                    th.addEventListener("click", function () {
                        sortGrid(column.fieldName);
                    });
                }

                header.appendChild(th);
            });

            if (metadata.permission.canEdit || metadata.permission.canDelete) {
                const actionTh = document.createElement("th");
                actionTh.innerText = "Actions";
                header.appendChild(actionTh);
            }
        }

        function renderRows(data) {
            const body = document.getElementById("gridBody");
            body.innerHTML = "";

            data.forEach((row, index) => {
                const tr = document.createElement("tr");

                metadata.columns.forEach(column => {
                    const td = document.createElement("td");
                    const value = row[column.fieldName];

                    if (column.dataType === "boolean") {
                        td.innerText = value ? "Yes" : "No";
                    } else {
                        td.innerText = value ?? "";
                    }

                    tr.appendChild(td);
                });

                if (metadata.permission.canEdit || metadata.permission.canDelete) {
                    const actionTd = document.createElement("td");

                    if (metadata.permission.canEdit) {
                        const editBtn = document.createElement("button");
                        editBtn.className = "btn btn-sm btn-warning me-2";
                        editBtn.innerText = "Edit";
                        editBtn.addEventListener("click", function () {
                            openEditForm(index);
                        });
                        actionTd.appendChild(editBtn);
                    }

                    if (metadata.permission.canDelete) {
                        const deleteBtn = document.createElement("button");
                        deleteBtn.className = "btn btn-sm btn-danger";
                        deleteBtn.innerText = "Delete";
                        deleteBtn.addEventListener("click", function () {
                            deleteEmployee(index);
                        });
                        actionTd.appendChild(deleteBtn);
                    }

                    tr.appendChild(actionTd);
                }

                body.appendChild(tr);
            });
        }

        function openAddForm() {
            editIndex = null;
            document.getElementById("formTitle").innerText = "Add Employee";
            renderDynamicForm({ isActive: true });
            document.getElementById("dynamicFormPanel").classList.remove("d-none");
        }

        function openEditForm(index) {
            editIndex = index;
            document.getElementById("formTitle").innerText = "Edit Employee";
            renderDynamicForm(employees[index]);
            document.getElementById("dynamicFormPanel").classList.remove("d-none");
        }

        function renderDynamicForm(rowData) {
            const formFieldsContainer = document.getElementById("formFields");
            formFieldsContainer.innerHTML = "";

            metadata.formFields.forEach(field => {
                const wrapper = document.createElement("div");
                wrapper.className = field.controlType === "checkbox"
                    ? "col-md-12 mb-3"
                    : "col-md-6 mb-3";

                const label = document.createElement("label");
                label.className = "form-label";
                label.innerText = field.displayLabel;

                const input = createInput(field, rowData[field.fieldName]);

                if (field.controlType === "checkbox") {
                    const checkWrapper = document.createElement("div");
                    checkWrapper.className = "form-check";

                    input.classList.add("form-check-input");

                    const checkLabel = document.createElement("label");
                    checkLabel.className = "form-check-label";
                    checkLabel.htmlFor = field.fieldName;
                    checkLabel.innerText = field.displayLabel;

                    checkWrapper.appendChild(input);
                    checkWrapper.appendChild(checkLabel);

                    wrapper.appendChild(checkWrapper);
                } else {
                    wrapper.appendChild(label);
                    wrapper.appendChild(input);
                }

                formFieldsContainer.appendChild(wrapper);
            });
        }

        function createInput(field, value) {
            let input;

            if (field.controlType === "checkbox") {
                input = document.createElement("input");
                input.type = "checkbox";
                input.checked =
    value === true ||
    value === "true" ||
    value === "True" ||
    value === "yes" ||
    value === "Yes" ||
    value === "active" ||
    value === "Active" ||
    value === 1 ||
    value === "1";
            }
            else if (field.controlType === "dropdown") {
                input = document.createElement("select");
                input.className = "form-select";

                const options = getDropdownOptions(field.fieldName);

                const emptyOption = document.createElement("option");
                emptyOption.value = "";
                emptyOption.text = "-- Select --";
                input.appendChild(emptyOption);

                options.forEach(optionValue => {
                    const option = document.createElement("option");
                    option.value = optionValue;
                    option.text = optionValue;

                    if (optionValue === value) {
                        option.selected = true;
                    }

                    input.appendChild(option);
                });
            }
            else {
                input = document.createElement("input");
                input.className = "form-control";
                input.type = field.dataType === "email" ? "email" : "text";
                input.value = value ?? "";
            }

            input.name = field.fieldName;
            input.id = field.fieldName;

            if (field.placeholder) {
                input.placeholder = field.placeholder;
            }

            if (field.isRequired) {
                input.required = true;
            }

            if (field.isReadOnly) {
                input.readOnly = true;
            }

            if (field.maxLength) {
                input.maxLength = field.maxLength;
            }

            return input;
        }

function getDropdownOptions(fieldName) {
    if (fieldName === "department") {
        return ["IT", "HR", "Finance", "Operations", "Sales"];
    }

    if (fieldName === "status") {
        return ["Active", "Inactive"];
    }

    return ["Option 1", "Option 2"];
}

        async function saveForm(event) {
            event.preventDefault();

            const form = document.getElementById("dynamicForm");
            const formData = new FormData(form);
            const employee = {};

            metadata.formFields.forEach(field => {
                if (field.controlType === "checkbox") {
                    employee[field.fieldName] = document.getElementById(field.fieldName).checked;
                } else {
                    employee[field.fieldName] = formData.get(field.fieldName);
                }
            });

            let response;

            if (editIndex === null) {
                response = await fetch("/api/employees", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(employee)
                });
            } else {
                const employeeId = employees[editIndex].id;

                response = await fetch(`/api/employees/${employeeId}`, {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(employee)
                });
            }

            if (!response.ok) {
                alert("Save failed.");
                return;
            }

            closeForm();
            await loadEmployees();
        }

        function closeForm() {
            document.getElementById("dynamicFormPanel").classList.add("d-none");
            document.getElementById("dynamicForm").reset();
            editIndex = null;
        }

        async function deleteEmployee(index) {
            if (!confirm("Are you sure you want to delete this employee?")) {
                return;
            }

            const employeeId = employees[index].id;

            const response = await fetch(`/api/employees/${employeeId}`, {
                method: "DELETE"
            });

            if (!response.ok) {
                alert("Delete failed.");
                return;
            }

            await loadEmployees();
        }

        function sortGrid(fieldName) {
            if (currentSortField === fieldName) {
                currentSortDirection = currentSortDirection === "asc" ? "desc" : "asc";
            } else {
                currentSortField = fieldName;
                currentSortDirection = "asc";
            }

            employees.sort((a, b) => {
                const valueA = a[fieldName] ?? "";
                const valueB = b[fieldName] ?? "";

                if (currentSortDirection === "asc") {
                    return valueA.toString().localeCompare(valueB.toString());
                }

                return valueB.toString().localeCompare(valueA.toString());
            });

            renderRows(employees);
        }

        function searchGrid() {
            const keyword = document.getElementById("searchBox").value.toLowerCase();

            const searchableColumns = metadata.columns
                .filter(x => x.isSearchable)
                .map(x => x.fieldName);

            const filtered = employees.filter(row =>
                searchableColumns.some(field =>
                    (row[field] ?? "").toString().toLowerCase().includes(keyword)
                )
            );

            renderRows(filtered);
        }
    </script>
}
